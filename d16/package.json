{
  "name": "crud-api-practice",
  "version": "1.0.0",
  "description": "Full CRUD API with validation and RESTful design using Express.js + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts --ext ts",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["crud", "express", "rest-api", "typescript"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.3.0"
  }
}
